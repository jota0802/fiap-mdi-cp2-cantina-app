{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(curl:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(ps:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx tsc*)",
      "Bash(npx expo:*)",
      "Bash(npx expo-doctor:*)",
      "Bash(npx ts-node:*)",
      "Bash(npx jest:*)",
      "Bash(git status*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git remote -v)",
      "Bash(git show:*)",
      "Bash(jq:*)",
      "Bash(ifconfig:*)",
      "Bash(ipconfig:*)",
      "Bash(netstat:*)",
      "Bash(sleep:*)",
      "Bash(until *)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git remote add:*)",
      "Bash(git remote remove:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh pr*)",
      "Bash(npm publish:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(chmod 777*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)"
    ]
  }
}
